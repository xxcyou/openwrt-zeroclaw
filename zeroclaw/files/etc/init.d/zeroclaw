#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

PROG="/usr/bin/zeroclaw"
CONFIG_NAME="zeroclaw"
RENDERER="/usr/libexec/zeroclaw/render-config.sh"

start_service() {
	local enabled host port workspace log_level

	config_load "$CONFIG_NAME"
	config_get_bool enabled main enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get host main host '127.0.0.1'
	config_get port main port '42617'
	config_get workspace main workspace '/var/lib/zeroclaw'
	config_get log_level main log_level 'info'

	mkdir -p /etc/zeroclaw "$workspace" /tmp/zeroclaw || return 1
	ZEROCLAW_RENDER_WORKSPACE="$workspace" "$RENDERER" || return 1

	procd_open_instance
	procd_set_param command "$PROG" daemon --host "$host" --port "$port"
	procd_set_param env ZEROCLAW_WORKSPACE="$workspace"
	procd_set_param env HOME="$workspace"
	procd_set_param env RUST_LOG="$log_level"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	return 0
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG_NAME"
}
